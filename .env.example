ANTHROPIC_API_KEY=sk-ant-...       # tu API key de platform.claude.com
CLICKUP_TOKEN=pk_...               # token personal de ClickUp
CLICKUP_TEAM_ID=1234567            # ID del workspace (lo encuentras en Settings → Team)
REPO_PATH=/ruta/a/tu/repo-php      # ruta absoluta al repo donde está PEST
WEBHOOK_PORT=3721                  # puerto del servidor webhook (opcional, default 3721)

# ── Modelos (opcionales, tienen default) ─────────────────────────────────────
# SCAFFOLD_MODEL=claude-haiku-4-5       # default, ~$0.01/tarea  (más barato)
# SCAFFOLD_MODEL=claude-sonnet-4-5      # ~$0.10/tarea           (mejor calidad)
# VALIDATE_MODEL=claude-sonnet-4-5      # default, ~$0.05/tarea
# VALIDATE_MODEL=claude-haiku-4-5       # ~$0.005/tarea          (más barato)

# ── Solo en servidor (Railway) ───────────────────────────────────────────────
# REPO_PATH=/data/repo-php         # en el servidor va una ruta DENTRO del contenedor (volumen)
# PHP_REPO_URL=https://oauth2:glpat-TUTOKEN@gitlab.com/sideralsoft/nevu/app.git
#   (Personal Access Token con scope read_repository. El usuario es literal "oauth2".
#    Con Deploy Token sería: https://gitlab+deploy-token-XXXX:TOKEN@gitlab.com/.../app.git)
# WEBHOOK_SECRET=                  # lo devuelve ClickUp al registrar el webhook
# GIT_AUTHOR_NAME=QA Agent
# GIT_AUTHOR_EMAIL=qa-agent@sideralsoft.com